# Kopieer dit bestand naar .env.local en vul de keys in. .env.local staat in .gitignore (wordt niet gecommit).

# Altum AI — Nederlandse vastgoeddata (https://altum.ai)
# Nodig voor Fase 0 (data-validatie) en de data-laag. Gratis account = ~50 calls.
ALTUM_API_KEY=

# Claude voor de AI-laag (verbouwkosten-inschatting + leesbare samenvatting).
# De code gebruikt de Vercel AI Gateway: maak een key aan op vercel.com → AI Gateway → API Keys.
# Zonder key werkt de app gewoon — het rapport is dan puur deterministisch (geen AI-velden).
AI_GATEWAY_API_KEY=
# Optioneel: ander model (default anthropic/claude-sonnet-4.6).
# DEALWIJS_AI_MODEL=anthropic/claude-haiku-4.5

# Optioneel: gratis analyses per IP per dag (default 5) — kostenbescherming Altum-credits.
# GRATIS_ANALYSES_PER_DAG=5
